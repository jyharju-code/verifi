# Verifi core engine configuration.
# Copy to .env for local development. In production this lives at
# /etc/verifi/env and is loaded by the systemd units.

DATABASE_URL=postgresql://verifi:verifi@localhost:5432/verifi

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
ADMIN_TELEGRAM_ID=

# polling for local development, webhook in production
BOT_MODE=polling
BOT_PORT=8701
CORE_API_PORT=8700
PUBLIC_BASE_URL=https://verifi.cloud

# Money
FREE_COMMISSION_USD=0.50
PAYOUTS_AUTO=false

# Admin dashboard at /admin. Generate: openssl rand -hex 24
DASHBOARD_TOKEN=

# Verify API instance (Node)
X402_PAY_TO=
X402_ENTRY_PRICE=$0.10
X402_UNLOCK_PRICE=$2.90
X402_NETWORK=eip155:8453
FACILITATOR_URL=https://x402.org/facilitator
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CORE_API_URL=http://127.0.0.1:8700
INSTANCE_ID=verify-api
