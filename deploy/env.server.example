# Server environment: /root/verifi/.env (chmod 600).
# Generated secrets: openssl rand -hex 24

POSTGRES_PASSWORD=
DASHBOARD_TOKEN=
LITELLM_MASTER_KEY=
TELEGRAM_WEBHOOK_SECRET=
# Shared secret guarding the core /internal money surface. Set the same value
# for core-api and verify-api. When empty, core falls back to network
# isolation only.
CORE_INTERNAL_SECRET=

DEEPSEEK_API_KEY=
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_ID=

PUBLIC_BASE_URL=https://verifi.cloud
BOT_MODE=polling
FREE_COMMISSION_USD=0.50
# Cap on free admissions per UTC day across all wallets (0 = unlimited).
# Recommended: set a finite ceiling so invented wallets cannot drain free
# human work. Over budget, callers fall through to paid x402.
FREE_DAILY_MAX=500

# x402 payments through the self-hosted facilitator.
# X402_PAY_TO: the receiving wallet address (public), revenue lands here.
# FACILITATOR_PRIVATE_KEY: the gas wallet private key, keep only 5-10 EUR
#   of ETH on Base in it. Never the treasury wallet key.
# When going live: FACILITATOR_URL=http://facilitator:8080 and start the
#   facilitator with the "payments" compose profile.
X402_PAY_TO=
X402_ENTRY_PRICE=$0.10
X402_UNLOCK_PRICE=$2.90
X402_NETWORK=eip155:8453
FACILITATOR_URL=https://x402.org/facilitator
FACILITATOR_PRIVATE_KEY=
